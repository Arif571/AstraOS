#!/bin/bash
# AstraOS Installer
# Usage: sudo astra-install

set -e

ASTRA_VERSION="1.0.0"

print_banner() {
clear
echo ""
echo "        ___         __               ____  _____"
echo "       /   |  _____/ /__________ _  / __ \/ ___/"
echo "      / /| | / ___/ __/ ___/ __ \`/ / / / /\__ \ "
echo "     / ___ |(__  ) /_/ /  / /_/ / / /_/ /___/ / "
echo "    /_/  |_/____/\__/_/   \__,_/  \____//____/  "
echo ""
echo "    ⭐  AstraOS Installer v$ASTRA_VERSION"
echo "    ================================================"
echo ""
}

check_root() {
  if [ "$EUID" -ne 0 ]; then
    echo "❌ Please run as root: sudo astra-install"
    exit 1
  fi
}

select_disk() {
  echo "📀 Available disks:"
  echo ""
  lsblk -d -o NAME,SIZE,MODEL | grep -v loop
  echo ""
  read -p "Enter disk to install (e.g. sda, vda, nvme0n1): " DISK
  DISK="/dev/$DISK"
  
  if [ ! -b "$DISK" ]; then
    echo "❌ Disk $DISK not found!"
    exit 1
  fi

  echo ""
  echo "⚠️  WARNING: All data on $DISK will be ERASED!"
  read -p "Type 'yes' to confirm: " CONFIRM
  if [ "$CONFIRM" != "yes" ]; then
    echo "❌ Installation cancelled."
    exit 0
  fi
}

select_mode() {
  echo ""
  echo "🌟 Select AstraOS Profile Mode:"
  echo ""
  echo "  1) 🧑‍💻 DevMode      — Developer & Programmer"
  echo "  2) 🛡️  ShieldMode   — Security & Privacy"
  echo "  3) 🖥️  DesktopMode  — General Desktop User"
  echo "  4) 🔬 LabMode      — Data Science & ML"
  echo ""
  read -p "Enter choice [1-4]: " MODE_CHOICE

  case $MODE_CHOICE in
    1) ASTRA_MODE="devmode" ;;
    2) ASTRA_MODE="shieldmode" ;;
    3) ASTRA_MODE="desktopmode" ;;
    4) ASTRA_MODE="labmode" ;;
    *) ASTRA_MODE="desktopmode" ;;
  esac

  echo "✅ Selected: $ASTRA_MODE"
}

get_user_info() {
  echo ""
  echo "👤 Create your user account:"
  echo ""
  read -p "Username: " USERNAME
  read -s -p "Password: " PASSWORD
  echo ""
  read -p "Hostname [astraos]: " HOSTNAME
  HOSTNAME=${HOSTNAME:-astraos}
}

partition_disk() {
  echo ""
  echo "🔧 Partitioning $DISK..."

  parted -s "$DISK" mklabel gpt
  parted -s "$DISK" mkpart ESP fat32 1MiB 512MiB
  parted -s "$DISK" set 1 esp on
  parted -s "$DISK" mkpart ROOT ext4 512MiB 100%

  if [[ "$DISK" == *"nvme"* ]]; then
    EFI="${DISK}p1"
    ROOT="${DISK}p2"
  else
    EFI="${DISK}1"
    ROOT="${DISK}2"
  fi

  mkfs.fat -F32 "$EFI"
  mkfs.ext4 -F "$ROOT"

  echo "✅ Partitioning done!"
}

install_system() {
  echo ""
  echo "📦 Installing AstraOS to $ROOT..."

  mount "$ROOT" /mnt
  mkdir -p /mnt/boot/efi
  mount "$EFI" /mnt/boot/efi

  # Copy live system
  cp -ax / /mnt/ 2>/dev/null || true
  unsquashfs -f -d /mnt /run/live/medium/live/filesystem.squashfs 2>/dev/null || true

  # Setup fstab
  ROOT_UUID=$(blkid -s UUID -o value "$ROOT")
  EFI_UUID=$(blkid -s UUID -o value "$EFI")

  cat > /mnt/etc/fstab << FSTAB
UUID=$ROOT_UUID /          ext4 defaults 0 1
UUID=$EFI_UUID  /boot/efi  vfat defaults 0 2
FSTAB

  echo "✅ System installed!"
}

configure_system() {
  echo ""
  echo "⚙️ Configuring system..."

  # Set hostname
  echo "$HOSTNAME" > /mnt/etc/hostname

  # Create user
  chroot /mnt useradd -m -s /bin/bash -G sudo,audio,video "$USERNAME" 2>/dev/null || true
  echo "$USERNAME:$PASSWORD" | chroot /mnt chpasswd

  # Set active mode
  echo "$ASTRA_MODE" > /mnt/etc/astraos/active-mode

  # Install GRUB
  chroot /mnt grub-install --target=x86_64-efi \
    --efi-directory=/boot/efi \
    --bootloader-id=AstraOS \
    --recheck

  chroot /mnt grub-mkconfig -o /boot/grub/grub.cfg

  echo "✅ Configuration done!"
}

finish() {
  umount -R /mnt 2>/dev/null || true
  echo ""
  echo "================================================"
  echo "  🎉 AstraOS installed successfully!"
  echo "  👤 Username : $USERNAME"
  echo "  🌟 Mode     : $ASTRA_MODE"
  echo "  💻 Hostname : $HOSTNAME"
  echo "================================================"
  echo ""
  read -p "🔄 Reboot now? [y/N]: " REBOOT
  if [ "$REBOOT" = "y" ] || [ "$REBOOT" = "Y" ]; then
    reboot
  fi
}

# Run installer
print_banner
check_root
select_disk
select_mode
get_user_info
partition_disk
install_system
configure_system
finish
